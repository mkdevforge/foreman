{
  "name": "foreman",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "foreman": "./foreman",
    "foreman-hook-stop-claude-code": "./foreman-hook-stop-claude-code",
    "foreman-hook-stop-codex": "./foreman-hook-stop-codex"
  },
  "scripts": {
    "build": "bun run build:ui && tsc --noEmit",
    "build:ui": "tailwindcss -i ./src/ui/styles.css -o ./src/ui/ui.css --minify",
    "test": "bun test",
    "test:ui-browser": "playwright test tests/ui/overview-browser.playwright.ts",
    "test:real-harness": "FOREMAN_REAL_HARNESS_TESTS=1 bun test --timeout=180000 tests/ingest/real-harness.test.ts"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "uuid": "^14.0.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4",
    "@types/bun": "^1.3.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
